{
  "ci": {
    "collect": {
      "startServerCommand": "npx vite --port 5178",
      "startServerReadyPattern": "ready in",
      "url": [
        "http://localhost:5178/",
        "http://localhost:5178/game.html?dev&gamePk=777242",
        "http://localhost:5178/guide.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "onlyCategories": ["performance", "best-practices"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:best-practices": ["error", { "minScore": 0.8 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
